    "^cargo (build|test|check|clippy|fmt)",
    "^git (status|log|diff|show)",
    "^ls ", "^dir ", "^find ", "^cat ", "^type ",
    "^grep ", "^echo ", "^pwd$", "^which ", "^where "
  ]
}
